# ─────────────────────────────────────────────────────────────
# Amazon Orders API — Production Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and replace the values with your actual secrets.
# NEVER commit the actual .env file to version control.

# ── Server ──────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── MongoDB ─────────────────────────────────────────────────
# Use your production MongoDB Atlas cluster URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/amazon_orders?retryWrites=true&w=majority

# ── Security ────────────────────────────────────────────────
# Use a highly secure, randomly generated string for JWT_SECRET
# e.g., openssl rand -base64 32
JWT_SECRET=super_secret_production_key_replace_me
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend domains
ALLOWED_ORIGINS=https://my-amazon-frontend.vercel.app,https://admin.my-amazon.com
